# CloudCrypt Environment Variables
# Copy this file to .env and fill in your values.
# docker compose automatically reads .env from the project root.

# ──────────────────────────────────────────────
# Encryption key for server-side file encryption.
# IMPORTANT: Set this to a strong, random secret in production.
# ──────────────────────────────────────────────
FILE_MASTER_KEY=changeme

# ──────────────────────────────────────────────
# The following are the defaults set in docker-compose.yml.
# Uncomment and change only if you need to override them.
# ──────────────────────────────────────────────

# PORT=8443
# CORS_ALLOWED_ORIGINS=http://localhost
# DB_PATH=/data/cloudcrypt.db
# DATA_DIR=/data
